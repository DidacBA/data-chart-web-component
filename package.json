  "keywords": [
    "web-components",
    "charts",
    "data-visualization",
    "data-chart"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DidacBA/data-chart-web-component"
  },
  "homepage": "https://github.com/DidacBA/data-chart-web-component",
  "bugs": {
    "url": "https://github.com/DidacBA/data-chart-web-component"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && vite build --mode docs",
    "build:lib": "tsc && vite build",
    "build:docs": "vite build --mode docs",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib"
  },
  "main": "./lib/data-chart.js",
  "module": "./lib/data-chart.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/data-chart.js",
      "default": "./lib/data-chart.js",
      "types": "./lib/index.d.ts"
    }
  },
  "sideEffects": [
    "./lib/data-chart.js"
  ],
  "files": [
    "/lib"
  ],
  "devDependencies": {
    "typescript": "~6.0.2",
    "unplugin-dts": "^1.0.3",
    "vite": "^8.1.0"
  }
